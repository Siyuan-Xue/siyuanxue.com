---
import Base from '../layouts/Base.astro';
import { bi } from '../i18n/types';

const title = bi('Under construction', '正在施工');
const description = bi(
	'This page is still under construction.',
	'这个页面还在施工中。',
);
---

<Base title={title} description={description}>
	<div class="container cc-narrow wip">
		<div class="wip-panel" role="status" aria-live="polite">
			{/*
			  Animated gavel based on Streamline “Justice Hammer” paths.
			  Colors use currentColor (site --fg) for light/dark.
			*/}
			<div class="wip-hammer" aria-hidden="true">
				<svg
					class="wip-hammer_svg"
					xmlns="http://www.w3.org/2000/svg"
					fill="none"
					viewBox="0 0 14 14"
					width="120"
					height="120"
				>
					{/* Sound block + base — stay put */}
					<g class="wip-block">
						<path
							fill="currentColor"
							fill-rule="evenodd"
							clip-rule="evenodd"
							opacity="0.42"
							d="M1.331 10.63a0.5 0.5 0 0 1 0.5 -0.5h5.5a0.5 0.5 0 0 1 0.5 0.5v1.75h-6.5v-1.75Z"
						/>
						<path
							fill="currentColor"
							fill-rule="evenodd"
							clip-rule="evenodd"
							opacity="0.72"
							d="M0.081 13.13a0.75 0.75 0 0 1 0.75 -0.75h7.5a0.75 0.75 0 0 1 0 1.5h-7.5a0.75 0.75 0 0 1 -0.75 -0.75Z"
						/>
					</g>

					{/* Gavel head + handle — swing to strike the block */}
					<g class="wip-gavel">
						<path
							fill="currentColor"
							opacity="0.9"
							d="M3.877 4.144a1.5 1.5 0 0 0 0 2.122l1.584 1.583a1.5 1.5 0 0 0 2.121 0l3.585 -3.585a1.5 1.5 0 0 0 0 -2.12L9.584 0.558a1.5 1.5 0 0 0 -2.122 0L3.877 4.144Z"
						/>
						<path
							fill="currentColor"
							fill-rule="evenodd"
							clip-rule="evenodd"
							opacity="0.78"
							d="m8.85 6.582 1.06 -1.06L13.7 9.31a0.75 0.75 0 1 1 -1.06 1.06L8.85 6.582Z"
						/>
					</g>

					{/*
					  Impact sparks: radial ticks around strike (6.8, 10.35).
					  CSS scales each ray from that origin at contact.
					*/}
					<g class="wip-sparks" fill="none" stroke="currentColor" stroke-linecap="round">
						<circle
							class="wip-spark-dot"
							cx="6.8"
							cy="10.35"
							r="0.3"
							fill="currentColor"
							stroke="none"
						/>
						{/* lines point “up” in local space; --rot fans them out */}
						<g class="wip-spark" style="--rot: -8deg">
							<line x1="6.8" y1="10.15" x2="6.8" y2="8.85" stroke-width="0.3" />
						</g>
						<g class="wip-spark" style="--rot: 42deg">
							<line x1="6.8" y1="10.15" x2="6.8" y2="8.95" stroke-width="0.26" />
						</g>
						<g class="wip-spark" style="--rot: 98deg">
							<line x1="6.8" y1="10.15" x2="6.8" y2="9.15" stroke-width="0.24" />
						</g>
						<g class="wip-spark" style="--rot: -52deg">
							<line x1="6.8" y1="10.15" x2="6.8" y2="8.9" stroke-width="0.26" />
						</g>
						<g class="wip-spark" style="--rot: -108deg">
							<line x1="6.8" y1="10.15" x2="6.8" y2="9.2" stroke-width="0.22" />
						</g>
						<g class="wip-spark" style="--rot: 158deg">
							<line x1="6.8" y1="10.15" x2="6.8" y2="9.3" stroke-width="0.2" />
						</g>
						<g class="wip-spark" style="--rot: 22deg">
							<line x1="6.8" y1="10.2" x2="6.8" y2="9.35" stroke-width="0.18" />
						</g>
						<g class="wip-spark" style="--rot: -78deg">
							<line x1="6.8" y1="10.2" x2="6.8" y2="9.4" stroke-width="0.16" />
						</g>
					</g>
				</svg>
			</div>

			<p class="wip-text">
				<span class="i18n-en" lang="en">Under construction…</span>
				<span class="i18n-zh" lang="zh-CN">正在施工...</span>
			</p>

			<p class="wip-back">
				<a href="/">
					<span class="i18n-en" lang="en">Back home</span>
					<span class="i18n-zh" lang="zh-CN">返回首页</span>
				</a>
			</p>
		</div>
	</div>
</Base>
