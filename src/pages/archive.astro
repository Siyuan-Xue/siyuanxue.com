---
import Base from '../layouts/Base.astro';
import I18n from '../components/I18n.astro';
import { site } from '../data/site';
import { getEssayPairs, getPostPairs, formatDateShort } from '../utils/content';
import type { Bi } from '../i18n/types';

const essays = await getEssayPairs();
const posts = await getPostPairs();

type ArchiveRow = {
	title: Bi;
	href: string;
	type: Bi;
	date: Date;
};

const rows: ArchiveRow[] = [
	...essays.map((e) => ({
		title: e.title,
		href: `/essay/${e.slug}/`,
		type: site.ui.essays,
		date: e.date,
	})),
	...posts.map((p) => ({
		title: p.title,
		href: `/post/${p.slug}/`,
		type: site.ui.posts,
		date: p.date,
	})),
].sort((a, b) => b.date.valueOf() - a.date.valueOf());
---

<Base title={site.ui.archive} description={site.description} htmlClass="page-archive">
	<div class="container cc-narrow">
		<section>
			<h2 class="h3">
				<I18n t={site.ui.archive} />
			</h2>
			{
				rows.length === 0 ? (
					<p>
						<I18n t={site.ui.emptyArchive} />
					</p>
				) : (
					<ul class="archive-list">
						{rows.map((row) => (
							<li class="archive-item">
								<span class="archive-type">
									<I18n t={row.type} />
								</span>
								<a href={row.href}>
									<I18n t={row.title} />
								</a>
								<span class="archive-date">
									<time datetime={row.date.toISOString()}>
										<span class="i18n-en" lang="en">
											{formatDateShort(row.date, 'en')}
										</span>
										<span class="i18n-zh" lang="zh-CN">
											{formatDateShort(row.date, 'zh')}
										</span>
									</time>
								</span>
							</li>
						))}
					</ul>
				)
			}
		</section>
	</div>
</Base>
