---
import type { Heading } from '../utils/headings';
import type { Bi } from '../i18n/types';

interface Props {
	en: Heading[];
	zh: Heading[];
	fallback: Bi;
}

const { en, zh, fallback } = Astro.props;
const enItems: Heading[] = en.length > 0
	? en
	: [{ depth: 2, text: fallback.en, id: 'top' }];
const zhItems: Heading[] = zh.length > 0
	? zh
	: [{ depth: 2, text: fallback.zh, id: 'top' }];

const tocLabel: Bi = { en: 'Contents', zh: '目录' };
---

	<nav id="site-toc" class="toc-container" data-toc-container data-toc-visibility>
			<div class="container cc-narrow cc-toc">
				<h2 class="h3 toc-contents-title">
					<span class="i18n-en" lang="en">
						{tocLabel.en}
					</span>
					<span class="i18n-zh" lang="zh-CN">
						{tocLabel.zh}
					</span>
				</h2>
				<div data-toc-list class="toc-list-wrap">
					<ul class="toc-list lang-body-en" lang="en">
							{enItems.map((h) => (
								<li class:list={['toc-list_item', h.depth === 3 && 'toc-list_item--h3']}>
									<a href={`#${h.id}`} class="toc-link" data-toc-link={h.id}>
										{h.text}
									</a>
								</li>
							))}
					</ul>
					<ul class="toc-list lang-body-zh" lang="zh-CN">
							{zhItems.map((h) => (
								<li class:list={['toc-list_item', h.depth === 3 && 'toc-list_item--h3']}>
									<a href={`#${h.id}`} class="toc-link" data-toc-link={h.id}>
										{h.text}
									</a>
								</li>
							))}
					</ul>
				</div>
			</div>
		</nav>

<script>
	const container = document.querySelector('[data-toc-container]');
	const toggle = document.querySelector('[data-toc-toggle]');
	let hideTimer: number | undefined;
	let isOpen = false;

	if (!(container instanceof HTMLElement)) {
		// no toc
	} else {
		// Keep the wider breakpoint required by this site's broader reading column.
		const mqDrawer = window.matchMedia('(max-width: 1479px)');

		function updateToggle(open: boolean) {
			if (toggle instanceof HTMLButtonElement) {
				const lang = document.documentElement.getAttribute('data-lang') === 'zh' ? 'zh' : 'en';
				const action = open ? 'close' : 'open';
				const label = toggle.getAttribute(`data-label-${action}-${lang}`) || 'Contents';

				toggle.setAttribute('aria-expanded', String(open));
				toggle.setAttribute('aria-label', label);
				toggle.setAttribute('title', label);
				toggle.classList.toggle('is-open', open);
			}
		}

		function setOpen(open: boolean, animate = true) {
			if (hideTimer !== undefined) {
				window.clearTimeout(hideTimer);
				hideTimer = undefined;
			}

			isOpen = open;
			updateToggle(open);
			document.body.style.overflow = open && mqDrawer.matches ? 'hidden' : '';

			if (open) {
				container.style.display = 'block';
				if (animate) {
					container.classList.add('is-closed');
					void container.offsetWidth;
				}
				container.classList.remove('is-closed');
			} else {
				container.classList.add('is-closed');
				if (animate) {
					hideTimer = window.setTimeout(() => {
						if (!isOpen) container.style.display = 'none';
					}, 300);
				} else {
					container.style.display = 'none';
				}
			}
		}

		function syncForViewport() {
			// Dario behavior: open by default beside the article, closed by default as a drawer.
			setOpen(!mqDrawer.matches, false);
		}

		if (toggle instanceof HTMLButtonElement) toggle.hidden = false;
		syncForViewport();
		mqDrawer.addEventListener('change', syncForViewport);

		if (toggle instanceof HTMLButtonElement) {
			toggle.addEventListener('click', () => {
				setOpen(!isOpen);
			});
		}

		container.querySelectorAll('a.toc-link').forEach((a) => {
			a.addEventListener('click', () => {
				if (mqDrawer.matches) setOpen(false);
			});
		});

		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape' && mqDrawer.matches && isOpen) {
				setOpen(false);
				toggle instanceof HTMLButtonElement && toggle.focus();
			}
		});

		document.addEventListener('site:language-change', () => updateToggle(isOpen));

		// Active link: opacity 1 via .cc-active (Dario)
		const links = Array.from(container.querySelectorAll<HTMLAnchorElement>('a[data-toc-link]'));
		const headings = Array.from(
			document.querySelectorAll<HTMLElement>('.prose h2[id], .prose h3[id]'),
		);

		if (headings.length && 'IntersectionObserver' in window) {
			const visible = new Set<string>();
			const io = new IntersectionObserver(
				(entries) => {
					for (const e of entries) {
						if (!(e.target instanceof HTMLElement) || !e.target.id) continue;
						if (e.isIntersecting) visible.add(e.target.id);
						else visible.delete(e.target.id);
					}
					let active: string | null = null;
					for (const h of headings) {
						if (visible.has(h.id)) {
							active = h.id;
							break;
						}
					}
					if (!active) {
						for (let i = headings.length - 1; i >= 0; i--) {
							if (headings[i].getBoundingClientRect().top <= 140) {
								active = headings[i].id;
								break;
							}
						}
					}
					links.forEach((a) => a.classList.toggle('cc-active', a.dataset.tocLink === active));
				},
				{ rootMargin: '-12% 0px -70% 0px', threshold: [0, 1] },
			);
			headings.forEach((h) => io.observe(h));
		}
	}
</script>
