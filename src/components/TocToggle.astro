---
/**
 * Dario places the hamburger in the header row (essay pages only).
 * Hidden in side-panel mode; used below 1480px to open the full TOC drawer.
 */
---

<button
	type="button"
	class="toc-toggle"
	data-toc-toggle
	hidden
	aria-expanded="false"
	aria-controls="site-toc"
	aria-label="Table of contents"
>
	<svg
		xmlns="http://www.w3.org/2000/svg"
		width="100%"
		viewBox="0 0 24 24"
		fill="none"
		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="round"
		stroke-linejoin="round"
		class="toc-toggle_icon cc-close"
		aria-hidden="true"
	>
		<line x1="18" y1="6" x2="6" y2="18"></line>
		<line x1="6" y1="6" x2="18" y2="18"></line>
	</svg>
	<svg
		xmlns="http://www.w3.org/2000/svg"
		width="100%"
		viewBox="0 0 24 24"
		fill="none"
		stroke="currentColor"
		stroke-width="2"
		stroke-linecap="round"
		stroke-linejoin="round"
		class="toc-toggle_icon cc-hamburger"
		aria-hidden="true"
	>
		<line x1="3" y1="12" x2="21" y2="12"></line>
		<line x1="3" y1="6" x2="21" y2="6"></line>
		<line x1="3" y1="18" x2="21" y2="18"></line>
	</svg>
</button>
